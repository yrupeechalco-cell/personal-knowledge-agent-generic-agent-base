{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人知识库 Agent",
  "version": "0.1.1",
  "identifier": "com.personal-knowledge-agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "个人知识库 Agent",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
