{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人知识库 Agent",
  "version": "0.2.2",
  "identifier": "com.personal-knowledge-agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "个人知识库 Agent",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": ["core:default", "updater:default"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3NTE2M0Q5RTQzMDgzRUIKUldUcmd6RGsyV05SOTBQeURWNXJveHo1QWhsL09ZYXhMNFFTaUNUdk9yQXZlZXdTeTY5aEJtaDMK",
      "endpoints": [
        "https://github.com/yrupeechalco-cell/personal-knowledge-agent-generic-agent-base/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
